# Ignore the configuration files generated by editors
.idea/
.vscode/

# Ignore the intermediate files of Python compilation
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore the virtual environment
venv/
env/

# Ignore the large model files generated during training
*.pt
*.pth

# Ignore the data set
data/emotion_dataset/
data/original/
data/raw/
data/temp/

# Ignore the log file
*.log

# Ignore the automatically generated pictures/charts
*.png
*.jpg

# Ignore other temporary files
.DS_Store
Thumbs.db

*.json
